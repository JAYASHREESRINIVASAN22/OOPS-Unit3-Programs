//9: Class Template

#include <iostream>
using namespace std;

template <class T>
class Calculator {
public:
    T add(T a, T b) {
        return a + b;
    }
};

int main() {
    Calculator<int> obj1;
    cout << obj1.add(2, 3) << endl;

    Calculator<float> obj2;
    cout << obj2.add(2.5, 3.5);
}
